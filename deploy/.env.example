# CrypSavvy backend — production env for the OCI VM.
#
# Copy to `.env` ON THE VM (next to docker-compose.yml — Compose auto-loads `.env`
# both for ${VAR} interpolation and to inject into the backend container), fill in
# real values, and `chmod 600 .env`. NEVER commit the filled-in file.
# Per-user secrets (CoinDCX keys, Telegram) are NOT here — they live encrypted in
# the database, supplied by each user via the settings page.

# ── Which image Watchtower runs (override only if your GHCR owner differs) ──────
BACKEND_IMAGE=ghcr.io/abhishekmthw/crypsavvy-backend:latest

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────────
# Zero Trust → Networks → Tunnels → create tunnel → copy the token.
# Then add a Public Hostname: api.<your-domain> → service http://backend:8000
CF_TUNNEL_TOKEN=

# ── Database (Postgres on Supabase) — same value you used on Railway ────────────
# postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Master Encryption Key (KEK) — MUST be the SAME key Railway used ─────────────
# Reusing the old key is REQUIRED to decrypt existing user credentials.
# (To generate a fresh one only for a brand-new DB:
#   python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
MASTER_ENCRYPTION_KEY=
# Optional decrypt-only fallback, used only during KEK rotation.
MASTER_ENCRYPTION_KEY_PREVIOUS=

# ── API Server ──────────────────────────────────────────────────────────────────
# Comma-separated frontend origins allowed to call the API. Include the exact
# Vercel origin (no trailing slash). PORT is left unset → defaults to 8000.
API_CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ── Clerk Authentication ──────────────────────────────────────────────────────
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json

# ── Live-trading gate ─────────────────────────────────────────────────────────
# Live mode is refused until this is "true". Enable only after validation
# (backtest GO + a healthy paper-trade window). See deploy/VALIDATION-RUNBOOK.md.
LIVE_TRADING_ENABLED=false

# ── Optional: shared sentiment APIs (Reddit). News RSS needs no keys. ───────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=crypto_bot/1.0 by your_reddit_username
