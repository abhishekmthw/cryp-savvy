# ── Database (Postgres on Supabase) ───────────────────────────────────────────
# Use the connection-pooler URL on port 6543 from Supabase project settings.
# Format: postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+psycopg://postgres.your_ref:your_password@aws-0-region.pooler.supabase.com:6543/postgres

# ── Master Encryption Key (KEK) ───────────────────────────────────────────────
# Generate locally with:
#   python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# Then paste the output below. App refuses to start without it.
MASTER_ENCRYPTION_KEY=
# Optional decrypt-only fallback used during KEK rotation. Leave empty unless rotating.
MASTER_ENCRYPTION_KEY_PREVIOUS=

# ── Operator-Owned Sentiment APIs (shared across all users) ──────────────────
# CryptoPanic free tier: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here
# Reddit free script app: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=crypto_bot/1.0 by your_reddit_username

# ── API Server ────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
API_CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ── Clerk Authentication ──────────────────────────────────────────────────────
# clerk.com → Dashboard → API Keys → Show JWKS URL
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json

# Per-user secrets (CoinDCX, Telegram) are NOT environment variables anymore —
# they live encrypted in the database, supplied by each user via the settings page.
