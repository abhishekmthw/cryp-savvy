# ── Trading Mode ──────────────────────────────────────────────────────────────
# Set to "paper" for simulation (safe) or "live" for real trading
MODE=paper

# ── CoinDCX API ───────────────────────────────────────────────────────────────
# Get these from: https://coindcx.com/settings/api (requires verified account)
COINDCX_API_KEY=your_coindcx_api_key_here
COINDCX_API_SECRET=your_coindcx_api_secret_here

# ── CryptoPanic API ───────────────────────────────────────────────────────────
# Free registration at: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here

# ── Reddit API ────────────────────────────────────────────────────────────────
# Create a free "script" app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=crypto_bot/1.0 by your_reddit_username

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get the token.
# Get your chat_id by messaging @userinfobot on Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── API Server ────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# In production: set this to your Vercel frontend URL.
API_CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Go to clerk.com → Dashboard → API Keys → Show JWKS URL
# Format: https://<your-clerk-domain>/.well-known/jwks.json
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json
