# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get both keys from clerk.com → Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk routing — these paths are handled by the (auth) route group
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Backend API ────────────────────────────────────────────────────────────────
# Local dev:    http://localhost:8000
# Production:   https://api.<your-domain>   (Cloudflare Tunnel → OCI backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (same host, different scheme)
# Local dev:    ws://localhost:8000
# Production:   wss://api.<your-domain>
NEXT_PUBLIC_WS_URL=ws://localhost:8000
