# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env
.env.local
.env*.local
# deploy/.env (OCI VM secrets) is already matched by `.env` above; guard the
# old `.env.production` name too, defensively. The *.example templates stay tracked.
.env.production

# ── Backend runtime data ──────────────────────────────────────────────────────
backend/data/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
dist/
build/

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
frontend/.next/
frontend/out/
*.tsbuildinfo

# ── Brand assets (source files kept locally — committed copy lives in frontend/public/) ──
/logo.png
/logo.svg

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
